FROM intel/pytorch:xpu-2.11.0-ubuntu24.04-20260608

WORKDIR /app

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --no-cache-dir \
    albumentations==2.0.8 \
    altair==6.0.0 \
    decord2==2.0.0 \
    einops==0.8.2 \
    fastapi==0.116.1 \
    ftfy==6.3.1 \
    iopath==0.1.10 \
    numpy==2.2.6 \
    opencv-python-headless==4.13.0.92 \
    pandas==2.3.3 \
    psutil==7.2.2 \
    prometheus-client==0.23.1 \
    pycocotools==2.0.11 \
    python-dotenv==1.2.2 \
    python-multipart==0.0.20 \
    regex==2026.7.19 \
    timm==1.0.25 \
    uvicorn==0.35.0

COPY third_party/sam3-auto-annotator/ /app/
COPY sam3/api.py /app/sam3_worker.py
COPY sam3/runtime.py /app/sam3_runtime.py
COPY sam3/secret-entrypoint.sh /usr/local/bin/sam3-secret-entrypoint

ENV SAM3_PLATFORM=intel_arc

ENTRYPOINT ["sam3-secret-entrypoint"]
CMD ["uvicorn", "sam3_worker:app", "--host", "0.0.0.0", "--port", "8004"]
