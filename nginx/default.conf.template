# Use Docker's internal DNS resolver for runtime-configured upstream hosts.
resolver 127.0.0.11 valid=30s;
resolver_timeout 5s;

map $http_x_forwarded_proto $forwarded_proto {
    default $http_x_forwarded_proto;
    ""      $scheme;
}

# Custom log format including request_time and upstream_response_time for status metrics
log_format ketrenet '$remote_addr - $remote_user [$time_local] "$request" '
                     '$status $body_bytes_sent $request_time $upstream_response_time '
                     '"$http_referer" "$http_user_agent"';
                     
server {
    listen 80;

    location /auto/ {
        client_max_body_size 1g;
        set $auto_backend "${AUTO_SAM_UPSTREAM_HOST}";
        rewrite ^/auto/(.*)$ /$1 break;
        proxy_pass http://$auto_backend:8090;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /auto;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location /mlflow/ {
        set $mlflow_backend "mlflow";
        rewrite ^/mlflow/(.*)$ /$1 break;
        proxy_pass http://$mlflow_backend:5000;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /mlflow;
    }

    location /ollama/ {
        set $ollama_backend "ollama";
        rewrite ^/ollama/(.*)$ /$1 break;
        proxy_pass http://$ollama_backend:11434;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 300s;
    }

    location /qdrant/ {
        set $qdrant_backend "qdrant";
        rewrite ^/qdrant/(.*)$ /$1 break;
        proxy_pass http://$qdrant_backend:6333;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /grafana {
        set $grafana_backend "grafana";
        proxy_pass http://$grafana_backend:3000;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $forwarded_proto;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    location / {
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $http_host;
        proxy_set_header X-NginX-Proxy true;
        proxy_pass_header Set-Cookie;
        proxy_pass_header P3P;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        set $backend "${OPEN_WEBUI_UPSTREAM_HOST}";
        proxy_pass http://$backend:8080;
    }
}
