# Non-secret Compose configuration. Store credentials under ./secrets/.
CLARE2_INFERENCE_MODEL=Qwen/Qwen3.6-27B-FP8
CLARE2_DISTILL_MODEL=Qwen/Qwen3.6-27B-FP8
CLARE2_TRAIN_MODEL=Qwen/Qwen3.6-27B-FP8
CLARE2_INFERENCE_REVISION=REPLACE_WITH_FP8_HF_REVISION
CLARE2_TRAIN_REVISION=REPLACE_WITH_TRAINING_HF_REVISION
CLARE2_BASE_CONFIG_HASH=REPLACE_WITH_SHA256
CLARE2_TOKENIZER_HASH=REPLACE_WITH_SHA256
CLARE2_PROJECT_MAP={"clare":"github:jketreno/clare","ai-vllm":"ai-vllm"}
CLARE2_PROJECT_ID=global
CLARE2_PROXY_PORT=8000
CLARE2_MCP_PORT=8002
CLARE2_BIND_ADDRESS=127.0.0.1
CLARE2_METRICS_PORT=9091
CLARE2_MODEL_CACHE=./models/huggingface
CLARE2_MLFLOW_PORT=5000
CLARE2_MLFLOW_VERSION=3.13.0
CLARE2_MLFLOW_EXPERIMENT=clare2-qlora
CLARE2_GPU_MEMORY_UTILIZATION=0.76
CLARE2_DOCKER_GID=REPLACE_WITH_DOCKER_SOCKET_GROUP_ID

SPAM_MODEL=Qwen/Qwen3.5-4B
SPAM_MODEL_REVISION=851bf6e806efd8d0a36b00ddf55e13ccb7b8cd0a
SPAM_GPU_MEMORY_UTILIZATION=0.20
SPAM_MAX_MODEL_LEN=16384
SPAM_THRESHOLD=0.80
SPAM_MAX_MESSAGE_CHARS=60000
SPAM_API_PORT=8003

ENABLE_LDAP=True
LDAP_SERVER_HOST=ldap.example.com
LDAP_SERVER_PORT=636
LDAP_USE_TLS=True
LDAP_APP_DN=cn=clare,ou=services,dc=example,dc=com
LDAP_SEARCH_BASE=ou=people,dc=example,dc=com
LDAP_SEARCH_FILTER=(uid=%(user)s)
LDAP_ATTRIBUTE_FOR_USERNAME=uid
LDAP_ATTRIBUTE_FOR_MAIL=mail
