{
  "title": "vLLM Inference",
  "uid": "vllm-inference",
  "tags": ["vllm"],
  "schemaVersion": 39,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Requests Running",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 6},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "vllm:num_requests_running", "legendFormat": "running"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "title": "Requests Waiting",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 6},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "vllm:num_requests_waiting", "legendFormat": "waiting"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 3,
      "title": "KV Cache Usage %",
      "type": "gauge",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 6},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "vllm:kv_cache_usage_perc * 100", "legendFormat": "KV cache"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 4,
      "title": "Prefix Cache Hit Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "rate(vllm:prefix_cache_hits_total[2m]) / rate(vllm:prefix_cache_queries_total[2m])",
          "legendFormat": "hit rate"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "id": 5,
      "title": "Spec Decode Accept Rate",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [
        {
          "datasource": {"uid": "prometheus"},
          "expr": "rate(vllm:spec_decode_num_accepted_tokens_total[2m]) / rate(vllm:spec_decode_num_draft_tokens_total[2m])",
          "legendFormat": "accept rate"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "id": 6,
      "title": "Token Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "rate(vllm:prompt_tokens_total[2m])", "legendFormat": "prompt tokens/s"},
        {"datasource": {"uid": "prometheus"}, "expr": "rate(vllm:generation_tokens_total[2m])", "legendFormat": "generation tokens/s"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 7,
      "title": "Engine Sleep State",
      "type": "stat",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 6},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "vllm:engine_sleep_state", "legendFormat": "awake"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "SLEEPING", "color": "orange"}, "1": {"text": "AWAKE", "color": "green"}}}]}}
    }
  ]
}
