{
  "title": "CLARE2 Pipeline",
  "uid": "clare2-pipeline",
  "tags": ["clare2"],
  "schemaVersion": 39,
  "refresh": "15s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Current Lifecycle Phase",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_lifecycle_phase == 1", "legendFormat": "{{phase}}"}
      ],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"1": {"text": "active", "color": "green"}, "0": {"text": "inactive", "color": "text"}}}]}}
    },
    {
      "id": 2,
      "title": "Active Proxy Requests",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "clare2_active_requests", "legendFormat": "requests"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 3,
      "title": "Lifecycle Maintenance Mode",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"datasource": {"uid": "prometheus"}, "expr": "clare2_maintenance_mode", "legendFormat": "maintenance"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"1": {"text": "ON", "color": "orange"}, "0": {"text": "OFF", "color": "green"}}}]}}
    },
    {
      "id": 4,
      "title": "Training Current",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "sum(clare2_corpus_tokens_total)", "legendFormat": "tokens (all projects)"},
        {"datasource": {"uid": "prometheus"}, "expr": "sum(clare2_corpus_sft_pairs)", "legendFormat": "SFT pairs (all projects)"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_training_loss_final", "legendFormat": "{{project}} final loss"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_training_duration_seconds", "legendFormat": "{{project}} train seconds"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 5,
      "title": "Routing Decisions / min",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "rate(clare2_routing_decisions_total[2m]) * 60", "legendFormat": "{{rule}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "rpm"}}
    },
    {
      "id": 6,
      "title": "Active Routes by Adapter",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_active_routes", "legendFormat": "{{adapter_id}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 7,
      "title": "Training Loss (Final)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_training_loss_final", "legendFormat": "{{project}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "points"}}}
    },
    {
      "id": 8,
      "title": "Training Loss by Epoch",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 10, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_training_loss_by_epoch", "legendFormat": "{{project}} epoch {{epoch}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 9,
      "title": "Distillation Last Run",
      "type": "stat",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_distillation_sessions_last", "legendFormat": "{{project}} sessions"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_distillation_patterns_extracted_last", "legendFormat": "{{project}} accepted"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_distillation_patterns_gated_out_last", "legendFormat": "{{project}} gated out"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_distillation_sessions_pending", "legendFormat": "{{project}} pending"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 10,
      "title": "Distillation Patterns / 24h",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_distillation_patterns_extracted_total[24h])", "legendFormat": "{{project}} / {{category}} accepted"},
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_distillation_patterns_gated_out_total[24h])", "legendFormat": "gated out"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 11,
      "title": "Distillation Sessions / 24h",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 22, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_distillation_sessions_total[24h])", "legendFormat": "{{project}} / {{outcome}}"},
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_distillation_patterns_raw_total[24h])", "legendFormat": "raw patterns / {{project}}"},
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_distillation_parse_errors_total[24h])", "legendFormat": "parse errors"},
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_structured_output_attempts_total{stage=\"distillation\"}[24h])", "legendFormat": "schema {{outcome}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 12,
      "title": "Summary Records",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 22, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_summary_records_input", "legendFormat": "{{project}} {{level}} input"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_summary_records_output", "legendFormat": "{{project}} {{level}} output"},
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_summary_parse_errors_total[1h])", "legendFormat": "{{level}} parse errors"},
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_structured_output_attempts_total{stage=~\"summary_.*\"}[1h])", "legendFormat": "{{stage}} {{outcome}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 13,
      "title": "Adapter Operations",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "rate(clare2_adapter_operations_total[2m]) * 60", "legendFormat": "{{operation}} / {{outcome}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "rpm"}}
    },
    {
      "id": 14,
      "title": "Lifecycle Outcomes",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "increase(clare2_lifecycle_outcomes_total[1h])", "legendFormat": "{{outcome}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 15,
      "title": "Policy Proxy Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 34, "w": 24, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.50, rate(clare2_proxy_duration_seconds_bucket[2m]))", "legendFormat": "p50"},
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.95, rate(clare2_proxy_duration_seconds_bucket[2m]))", "legendFormat": "p95"},
        {"datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.99, rate(clare2_proxy_duration_seconds_bucket[2m]))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 16,
      "title": "Corpus Training Signal by Project",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 40, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_corpus_tokens_total", "legendFormat": "{{project}} tokens"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_corpus_sft_pairs", "legendFormat": "{{project}} SFT pairs"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 17,
      "title": "Adapter Size / Training Duration by Project",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 40, "w": 12, "h": 6},
      "targets": [
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_adapter_size_bytes", "legendFormat": "{{project}} size"},
        {"datasource": {"uid": "prometheus"}, "expr": "clare2_training_duration_seconds", "legendFormat": "{{project}} duration"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
